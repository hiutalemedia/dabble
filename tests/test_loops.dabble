-- test_loops.dabble

let items = SELECT * FROM (VALUES
    (1, 'apple',  'fruit',  1.20),
    (2, 'carrot', 'veg',    0.80),
    (3, 'banana', 'fruit',  0.60),
    (4, 'pea',    'veg',    0.40),
    (5, 'cherry', 'fruit',  2.00)
    ) AS t(id, name, category, price);

-- Basic for loop
CREATE TEMP TABLE fruit_names (name VARCHAR);
for row in items WHERE category = 'fruit':
    INSERT INTO fruit_names VALUES (row.name);

check (COUNT(*) = 3 FROM fruit_names) else fail 'for loop row count failed';
check (COUNT(*) = 1 FROM fruit_names WHERE name = 'banana') else fail 'for loop value failed';

-- Inline query source
CREATE TEMP TABLE cheap (name VARCHAR);
for row in (SELECT name, price FROM items WHERE price < 1.0 ORDER BY price):
    INSERT INTO cheap VALUES (row.name);

check (COUNT(*) = 3 FROM cheap) else fail 'for inline query count failed';

-- Enumerated for: i, row
CREATE TEMP TABLE ranked (rank_n INTEGER, name VARCHAR);
for i, row in items ORDER BY price DESC:
    INSERT INTO ranked VALUES (i, row.name);

check (COUNT(*) = 5 FROM ranked) else fail 'for enumeration count failed';
check (COUNT(*) = 1 FROM ranked WHERE rank_n = 1 AND name = 'cherry') else fail 'for enum rank 1 failed';
check (COUNT(*) = 1 FROM ranked WHERE rank_n = 5 AND name = 'pea') else fail 'for enum rank 5 failed';

-- break: stop after first item
CREATE TEMP TABLE first_only (name VARCHAR);
for row in items ORDER BY id:
    INSERT INTO first_only VALUES (row.name);
    break;

check (COUNT(*) = 1 FROM first_only) else fail 'for break count failed';
check (COUNT(*) = 1 FROM first_only WHERE name = 'apple') else fail 'for break value failed';

-- continue: skip veg
CREATE TEMP TABLE non_veg (name VARCHAR);
for row in items:
    if (row.category = 'veg'):
        continue;
    INSERT INTO non_veg VALUES (row.name);

check (COUNT(*) = 3 FROM non_veg) else fail 'for continue count failed';
check (COUNT(*) = 0 FROM non_veg WHERE name = 'carrot') else fail 'for continue skipped wrong';

-- table.column shorthand
CREATE TEMP TABLE all_names (name VARCHAR);
for name in items.name:
    INSERT INTO all_names VALUES (name);

check (COUNT(*) = 5 FROM all_names) else fail 'for column shorthand failed';

-- while with val mutation
val counter = 0;
while (counter < 5):
    counter = counter + 1;
check (counter = 5) else fail 'while val mutation failed';

-- while with break
val n = 0;
while (n < 100):
    n = n + 1;
    if (n = 7):
        break;
check (n = 7) else fail 'while break failed';

-- while with continue (odd sum 1+3+5+7+9=25)
val odd_sum = 0;
val wi = 0;
while (wi < 10):
    wi = wi + 1;
    if (wi % 2 = 0):
        continue;
    odd_sum = odd_sum + wi;
check (odd_sum = 25) else fail 'while continue failed';

print 'PASS: test_loops';
