{
  "name": "Dabble",
  "scopeName": "source.dabble",
  "fileTypes": ["dabble"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#template_vars" },
    { "include": "#strings" },
    { "include": "#dabble_keywords" },
    { "include": "#export_operators" },
    { "include": "#sql_keywords" },
    { "include": "#sql_functions" },
    { "include": "#numbers" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "name": "comment.line.double-dash.dabble",
      "match": "--.*"
    },
    "template_vars": {
      "name": "meta.template.dabble",
      "match": "(\\{\\{)([^}]*?)(\\}\\})",
      "captures": {
        "1": { "name": "punctuation.definition.template.begin.dabble" },
        "2": { "name": "variable.other.template.dabble" },
        "3": { "name": "punctuation.definition.template.end.dabble" }
      }
    },
    "strings": {
      "name": "string.quoted.single.dabble",
      "begin": "'",
      "end": "'",
      "patterns": [
        { "include": "#template_vars" },
        { "name": "constant.character.escape.dabble", "match": "''" }
      ]
    },
    "dabble_keywords": {
      "name": "keyword.control.dabble",
      "match": "\\b(let|val|scalar|table|projection|proj|cols|fn|for|while|if|else|expect|check|print|import|in)\\b"
    },
    "export_operators": {
      "patterns": [
        { "name": "keyword.operator.export.dabble", "match": "->" },
        { "name": "keyword.operator.export.append.dabble", "match": ">>" }
      ]
    },
    "sql_keywords": {
      "name": "keyword.other.sql.dabble",
      "match": "(?i)\\b(SELECT|FROM|WHERE|JOIN|LEFT|RIGHT|INNER|OUTER|FULL|CROSS|ON|AND|OR|NOT|IN|IS|NULL|AS|BY|GROUP|ORDER|HAVING|LIMIT|OFFSET|DISTINCT|UNION|EXCEPT|INTERSECT|WITH|INSERT|UPDATE|DELETE|CREATE|DROP|ALTER|TABLE|TEMP|TEMPORARY|VIEW|INDEX|INTO|VALUES|SET|CASE|WHEN|THEN|ELSE|END|EXISTS|BETWEEN|LIKE|ILIKE|ATTACH|DETACH|USE|INSTALL|LOAD|COPY|FORMAT|HEADER|ASC|DESC|OVER|PARTITION|WINDOW|QUALIFY|SAMPLE|RETURNING)\\b"
    },
    "sql_functions": {
      "name": "support.function.sql.dabble",
      "match": "(?i)\\b(COUNT|SUM|AVG|MIN|MAX|ROUND|FLOOR|CEIL|ABS|COALESCE|NULLIF|IFNULL|IIF|CAST|TRY_CAST|TYPEOF|DATE_PART|DATE_TRUNC|NOW|TODAY|CURRENT_DATE|CURRENT_TIMESTAMP|EPOCH|STRFTIME|STRPTIME|LENGTH|UPPER|LOWER|TRIM|LTRIM|RTRIM|SUBSTR|SUBSTRING|REPLACE|SPLIT|STRING_AGG|LIST_AGG|ARRAY_AGG|ROW_NUMBER|RANK|DENSE_RANK|LAG|LEAD|FIRST_VALUE|LAST_VALUE|NTILE|GETVARIABLE|READ_CSV|READ_PARQUET|READ_JSON)\\b(?=\\s*\\()"
    },
    "numbers": {
      "name": "constant.numeric.dabble",
      "match": "\\b\\d+\\.?\\d*\\b"
    },
    "operators": {
      "name": "keyword.operator.dabble",
      "match": "(\\|\\||!=|<>|<=|>=|<|>|=|\\+|-|\\*|\\/|%|::)"
    }
  }
}